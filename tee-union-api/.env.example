# ──────────────────────────────────────────────────────────────────────────────
# TEE 1104 Union API — Environment Variables
# Copy this file to .env and fill in values before running the application.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development                  # development | production | test
PORT=3000

# ── Database (required) ───────────────────────────────────────────────────────
# PostgreSQL connection string. For Docker dev: postgres://teeuser:teepass@localhost:5432/tee_union
DATABASE_URL=postgresql://teeuser:teepass@localhost:5432/tee_union

# ── JWT (required) ────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Redis / BullMQ (optional) ─────────────────────────────────────────────────
# The API starts without Redis — Telegram/SMS fallback jobs simply won't queue.
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=                     # Leave blank for local dev (no auth)

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave blank to allow all origins (development only — lock down in production).
# CORS_ORIGINS=https://myapp.example.com,exp://192.168.1.10:8081

# ── Firebase Cloud Messaging / FCM (optional) ────────────────────────────────
# All three must be set together, or all left blank.
# App gracefully skips FCM push if any of these are missing.
# Obtain from Firebase Console → Project Settings → Service Accounts → Generate Key
# FCM_PROJECT_ID=tee-union-XXXXX
# FCM_CLIENT_EMAIL=firebase-adminsdk-xxx@tee-union-XXXXX.iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Obtain token from @BotFather on Telegram.
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_WEBHOOK_SECRET=a-random-secret-for-hmac-verification

# ── AWS SNS / SMS (optional) ──────────────────────────────────────────────────
# All three must be set together, or all left blank.
# IAM user needs sns:Publish permission.
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
