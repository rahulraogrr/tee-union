// =============================================================================
//  TEE 1104 Union — Prisma Schema
//  Mirrors tee_1104_union_schema_v6.sql exactly.
//  All table names use @@map("t_*") to match the t_ prefix convention.
//  Backend: NestJS + Prisma | DB: PostgreSQL
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMs
// ---------------------------------------------------------------------------

enum UserRole {
  super_admin
  admin
  zonal_officer
  rep
  member

  @@map("user_role")
}

enum MaritalStatusType {
  single
  married
  widowed
  divorced

  @@map("marital_status_type")
}

enum TicketPriority {
  standard
  urgent
  critical

  @@map("ticket_priority")
}

enum TicketStatus {
  open
  in_progress
  escalated
  resolved
  closed

  @@map("ticket_status")
}

enum NotificationType {
  ticket_update
  news
  event
  system

  @@map("notification_type")
}

enum PlatformType {
  ios
  android

  @@map("platform_type")
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE

  @@map("audit_action")
}

enum UnitType {
  circle
  branch
  depot
  division
  zone
  section

  @@map("unit_type")
}

// ---------------------------------------------------------------------------
// 1. UNION IDENTITY
// ---------------------------------------------------------------------------

model Union {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String    @db.VarChar(200)
  shortName          String    @map("short_name") @db.VarChar(50)
  description        String?   @db.Text
  unionType          String    @map("union_type") @db.VarChar(100)
  registrationNumber String?   @map("registration_number") @db.VarChar(100)
  foundedDate        DateTime? @map("founded_date") @db.Date
  hoPhone            String?   @map("ho_phone") @db.VarChar(15)
  hoEmail            String?   @map("ho_email") @db.VarChar(150)
  hoAddress          Json?     @map("ho_address")
  logoUrl            String?   @map("logo_url") @db.VarChar(500)
  primaryColor       String    @default("#1F4E79") @map("primary_color") @db.VarChar(10)
  defaultLanguageId  String?   @map("default_language_id") @db.Uuid
  updatedAt          DateTime  @default(now()) @map("updated_at")

  defaultLanguage Language? @relation(fields: [defaultLanguageId], references: [id])

  @@map("t_union")
}

// ---------------------------------------------------------------------------
// 2. LANGUAGES
// ---------------------------------------------------------------------------

model Language {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  nativeName String   @map("native_name") @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  unions       Union[]
  translations Translation[]

  @@map("t_languages")
}

// ---------------------------------------------------------------------------
// 3. TRANSLATIONS
// ---------------------------------------------------------------------------

model Translation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  languageId String   @map("language_id") @db.Uuid
  field      String   @db.VarChar(100)
  value      String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  language Language @relation(fields: [languageId], references: [id])

  @@unique([entityType, entityId, languageId, field])
  @@index([entityType, entityId, languageId])
  @@map("t_translations")
}

// ---------------------------------------------------------------------------
// 4. GEOGRAPHY
// ---------------------------------------------------------------------------

model Country {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  states State[]

  @@map("t_countries")
}

model State {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryId String   @map("country_id") @db.Uuid
  name      String   @db.VarChar(100)
  code      String   @unique @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  country   Country    @relation(fields: [countryId], references: [id])
  districts District[]
  employers Employer[]

  @@map("t_states")
}

model District {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stateId   String   @map("state_id") @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  state                      State                      @relation(fields: [stateId], references: [id])
  workUnits                  WorkUnit[]
  members                    Member[]
  repAssignments             RepAssignment[]
  tickets                    Ticket[]
  memberDesignationHistories MemberDesignationHistory[]
  events                     Event[]

  @@map("t_districts")
}

model WorkUnit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  districtId String   @map("district_id") @db.Uuid
  name       String   @db.VarChar(150)
  unitType   UnitType @map("unit_type")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  district                   District                   @relation(fields: [districtId], references: [id])
  members                    Member[]
  repAssignments             RepAssignment[]
  tickets                    Ticket[]
  memberDesignationHistories MemberDesignationHistory[]

  @@index([districtId])
  @@map("t_work_units")
}

model Employer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stateId   String   @map("state_id") @db.Uuid
  name      String   @db.VarChar(200)
  shortName String   @map("short_name") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  state                      State                      @relation(fields: [stateId], references: [id])
  members                    Member[]
  memberDesignationHistories MemberDesignationHistory[]

  @@map("t_employers")
}

// ---------------------------------------------------------------------------
// 5. AUTHENTICATION & USERS
// ---------------------------------------------------------------------------

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId       String    @unique @map("employee_id") @db.VarChar(50)
  mobileNo         String    @map("mobile_no") @db.VarChar(15)
  email            String?   @db.VarChar(150)
  pinHash          String    @map("pin_hash") @db.VarChar(255)
  oneTimePinHash   String?   @map("one_time_pin_hash") @db.VarChar(255)
  role             UserRole
  isPinChanged     Boolean   @default(false) @map("is_pin_changed")
  isActive         Boolean   @default(true) @map("is_active")
  createdById      String?   @map("created_by") @db.Uuid
  lastLoginAt      DateTime? @map("last_login_at")
  telegramChatId   BigInt?   @unique @map("telegram_chat_id")
  telegramLinkedAt DateTime? @map("telegram_linked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")

  createdBy              User?                      @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers           User[]                     @relation("UserCreatedBy")
  staffProfile           StaffProfile?
  member                 Member?
  repAssignments         RepAssignment[]
  assignedTickets        Ticket[]                   @relation("AssignedRep")
  zonalTickets           Ticket[]                   @relation("AssignedZonalOfficer")
  ticketComments         TicketComment[]
  statusChanges          TicketStatusHistory[]
  notifications          Notification[]
  pushTokens             PushToken[]
  publishedNews          News[]
  createdEvents          Event[]
  auditLogs              AuditLog[]
  designationChanges     MemberDesignationHistory[]
  telegramLinkTokens     TelegramLinkToken[]

  @@index([employeeId])
  @@index([role])
  @@map("t_users")
}

model StaffProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  fullName    String   @map("full_name") @db.VarChar(150)
  mobileNo    String   @map("mobile_no") @db.VarChar(15)
  designation String?  @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("t_staff_profiles")
}

// ---------------------------------------------------------------------------
// 6. MEMBERS
// ---------------------------------------------------------------------------

model Designation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  members                    Member[]
  memberDesignationHistories MemberDesignationHistory[]

  @@map("t_designations")
}

model Member {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String             @unique @map("user_id") @db.Uuid
  employeeId              String             @map("employee_id") @db.VarChar(50)
  employerId              String             @map("employer_id") @db.Uuid
  designationId           String             @map("designation_id") @db.Uuid
  fullName                String             @map("full_name") @db.VarChar(200)
  districtId              String             @map("district_id") @db.Uuid
  workUnitId              String?            @map("work_unit_id") @db.Uuid
  memberSince             DateTime           @map("member_since") @db.Date
  dateOfBirth             DateTime?          @map("date_of_birth") @db.Date
  mobileNo                String             @map("mobile_no") @db.VarChar(15)
  maritalStatus           MaritalStatusType? @map("marital_status")
  marriageAnniversaryDate DateTime?          @map("marriage_anniversary_date") @db.Date
  currentAddress          Json?              @map("current_address")
  permanentAddress        Json?              @map("permanent_address")
  profileComplete         Boolean            @default(false) @map("profile_complete")
  isActive                Boolean            @default(true) @map("is_active")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @default(now()) @map("updated_at")

  user                       User                       @relation(fields: [userId], references: [id])
  employer                   Employer                   @relation(fields: [employerId], references: [id])
  designation                Designation                @relation(fields: [designationId], references: [id])
  district                   District                   @relation(fields: [districtId], references: [id])
  workUnit                   WorkUnit?                  @relation(fields: [workUnitId], references: [id])
  tickets                    Ticket[]
  eventRegistrations         EventRegistration[]
  memberDesignationHistories MemberDesignationHistory[]

  @@index([districtId])
  @@index([workUnitId])
  @@index([employerId])
  @@index([designationId])
  @@index([isActive])
  @@map("t_members")
}

model MemberDesignationHistory {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId      String    @map("member_id") @db.Uuid
  designationId String    @map("designation_id") @db.Uuid
  employerId    String    @map("employer_id") @db.Uuid
  workUnitId    String?   @map("work_unit_id") @db.Uuid
  districtId    String?   @map("district_id") @db.Uuid
  validFrom     DateTime  @map("valid_from") @db.Date
  validTo       DateTime? @map("valid_to") @db.Date
  changedById   String    @map("changed_by") @db.Uuid
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  member      Member      @relation(fields: [memberId], references: [id])
  designation Designation @relation(fields: [designationId], references: [id])
  employer    Employer    @relation(fields: [employerId], references: [id])
  workUnit    WorkUnit?   @relation(fields: [workUnitId], references: [id])
  district    District?   @relation(fields: [districtId], references: [id])
  changedBy   User        @relation(fields: [changedById], references: [id])

  @@unique([memberId, validFrom])
  @@index([memberId])
  @@index([memberId, validFrom])
  @@index([validTo])
  @@map("t_member_designation_history")
}

model RepAssignment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  districtId   String   @map("district_id") @db.Uuid
  workUnitId   String?  @map("work_unit_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedById String?  @map("assigned_by") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")

  user     User      @relation(fields: [userId], references: [id])
  district District  @relation(fields: [districtId], references: [id])
  workUnit WorkUnit? @relation(fields: [workUnitId], references: [id])

  @@index([districtId, isActive])
  @@index([userId, isActive])
  @@map("t_rep_assignments")
}

// ---------------------------------------------------------------------------
// 7. TICKETING & GRIEVANCES
// ---------------------------------------------------------------------------

model TicketCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(150)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tickets Ticket[]

  @@map("t_ticket_categories")
}

model Ticket {
  id                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId               String         @map("member_id") @db.Uuid
  assignedRepId          String?        @map("assigned_rep_id") @db.Uuid
  assignedZonalOfficerId String?        @map("assigned_zonal_officer_id") @db.Uuid
  categoryId             String?        @map("category_id") @db.Uuid
  title                  String         @db.VarChar(200)
  description            String?        @db.Text
  priority               TicketPriority @default(standard)
  status                 TicketStatus   @default(open)
  districtId             String?        @map("district_id") @db.Uuid
  workUnitId             String?        @map("work_unit_id") @db.Uuid
  slaDeadline            DateTime       @map("sla_deadline")
  resolvedAt             DateTime?      @map("resolved_at")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @default(now()) @map("updated_at")

  member               Member               @relation(fields: [memberId], references: [id])
  assignedRep          User?                @relation("AssignedRep", fields: [assignedRepId], references: [id])
  assignedZonalOfficer User?                @relation("AssignedZonalOfficer", fields: [assignedZonalOfficerId], references: [id])
  category             TicketCategory?      @relation(fields: [categoryId], references: [id])
  district             District?            @relation(fields: [districtId], references: [id])
  workUnit             WorkUnit?            @relation(fields: [workUnitId], references: [id])
  comments             TicketComment[]
  statusHistory        TicketStatusHistory[]

  @@index([status])
  @@index([memberId])
  @@index([assignedRepId])
  @@index([assignedZonalOfficerId])
  @@index([slaDeadline])
  @@index([districtId])
  @@index([createdAt])
  @@map("t_tickets")
}

model TicketComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String   @map("ticket_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  comment    String   @db.Text
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("t_ticket_comments")
}

model TicketStatusHistory {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId    String       @map("ticket_id") @db.Uuid
  changedById String       @map("changed_by") @db.Uuid
  oldStatus   TicketStatus @map("old_status")
  newStatus   TicketStatus @map("new_status")
  notes       String?      @db.Text
  changedAt   DateTime     @default(now()) @map("changed_at")

  ticket    Ticket @relation(fields: [ticketId], references: [id])
  changedBy User   @relation(fields: [changedById], references: [id])

  @@index([ticketId])
  @@index([changedAt])
  @@map("t_ticket_status_history")
}

// ---------------------------------------------------------------------------
// 8. NEWS & EVENTS
// ---------------------------------------------------------------------------

model News {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titleEn       String    @map("title_en") @db.VarChar(250)
  titleTe       String?   @map("title_te") @db.VarChar(250)
  bodyEn        String    @map("body_en") @db.Text
  bodyTe        String?   @map("body_te") @db.Text
  publishedById String?   @map("published_by") @db.Uuid
  isPublished   Boolean   @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @map("updated_at")

  publishedBy User? @relation(fields: [publishedById], references: [id])

  @@index([isPublished, publishedAt])
  @@map("t_news")
}

model Event {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titleEn       String    @map("title_en") @db.VarChar(250)
  titleTe       String?   @map("title_te") @db.VarChar(250)
  descriptionEn String?   @map("description_en") @db.Text
  descriptionTe String?   @map("description_te") @db.Text
  eventDate     DateTime  @map("event_date")
  location      String?   @db.VarChar(300)
  maxCapacity   Int?      @map("max_capacity")
  isVirtual     Boolean   @default(false) @map("is_virtual")
  districtId    String?   @map("district_id") @db.Uuid
  createdById   String?   @map("created_by") @db.Uuid
  isPublished   Boolean   @default(false) @map("is_published")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @map("updated_at")

  district      District?           @relation(fields: [districtId], references: [id])
  createdBy     User?               @relation(fields: [createdById], references: [id])
  registrations EventRegistration[]

  @@index([eventDate])
  @@index([districtId])
  @@map("t_events")
}

model EventRegistration {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId      String   @map("event_id") @db.Uuid
  memberId     String   @map("member_id") @db.Uuid
  registeredAt DateTime @default(now()) @map("registered_at")

  event  Event  @relation(fields: [eventId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
  @@map("t_event_registrations")
}

// ---------------------------------------------------------------------------
// 9. NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  title        String           @db.VarChar(200)
  body         String           @db.Text
  type         NotificationType
  referenceId  String?          @map("reference_id") @db.Uuid
  isRead       Boolean          @default(false) @map("is_read")
  sentAt       DateTime         @default(now()) @map("sent_at")
  readAt       DateTime?        @map("read_at")
  fcmSent      Boolean          @default(false) @map("fcm_sent")
  telegramSent Boolean          @default(false) @map("telegram_sent")
  smsSent      Boolean          @default(false) @map("sms_sent")
  deliveredVia String?          @map("delivered_via") @db.VarChar(20)
  isCritical   Boolean          @default(false) @map("is_critical")
  isUrgent     Boolean          @default(false) @map("is_urgent")

  user User                  @relation(fields: [userId], references: [id])
  jobs NotificationJob[]

  @@index([userId, isRead])
  @@index([sentAt])
  @@index([fcmSent, isRead, sentAt])
  @@map("t_notifications")
}

model TelegramLinkToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(10)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("t_telegram_link_tokens")
}

model NotificationJob {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId String    @map("notification_id") @db.Uuid
  channel        String    @db.VarChar(20)
  scheduledAt    DateTime  @map("scheduled_at")
  processedAt    DateTime? @map("processed_at")
  skipped        Boolean   @default(false)
  skipReason     String?   @map("skip_reason") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@map("t_notification_jobs")
}

model PushToken {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  token      String       @db.Text
  platform   PlatformType
  createdAt  DateTime     @default(now()) @map("created_at")
  lastUsedAt DateTime?    @map("last_used_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("t_push_tokens")
}

// ---------------------------------------------------------------------------
// 10. AUDIT LOG
// ---------------------------------------------------------------------------

model AuditLog {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName   String      @map("table_name") @db.VarChar(100)
  recordId    String      @map("record_id") @db.Uuid
  action      AuditAction
  changedById String?     @map("changed_by") @db.Uuid
  oldValues   Json?       @map("old_values")
  newValues   Json?       @map("new_values")
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  userAgent   String?     @map("user_agent") @db.VarChar(500)
  createdAt   DateTime    @default(now()) @map("created_at")

  changedBy User? @relation(fields: [changedById], references: [id])

  @@index([tableName, recordId])
  @@index([changedById])
  @@index([createdAt])
  @@index([tableName])
  @@map("t_audit_logs")
}
