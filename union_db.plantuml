node12  -[#595959,plain]-^  node10 : "user_id:id"
node12  -[#595959,plain]-^  node10 : "assigned_by:id"
node12  -[#595959,plain]-^  node3  : "work_unit_id:id"
node7   -[#595959,plain]-^  node10 : "user_id:id"
node13  -[#595959,plain]-^  node11 : "country_id:id"
node20  -[#595959,plain]-^  node15 : "ticket_id:id"
node20  -[#595959,plain]-^  node10 : "user_id:id"
node5   -[#595959,plain]-^  node15 : "ticket_id:id"
node5   -[#595959,plain]-^  node10 : "changed_by:id"
node15  -[#595959,plain]-^  node0  : "district_id:id"
node15  -[#595959,plain]-^  node14 : "member_id:id"
node15  -[#595959,plain]-^  node4  : "category_id:id"
node15  -[#595959,plain]-^  node10 : "assigned_zonal_officer_id:id"
node15  -[#595959,plain]-^  node10 : "assigned_rep_id:id"
node15  -[#595959,plain]-^  node3  : "work_unit_id:id"
node23  -[#595959,plain]-^  node18 : "language_id:id"
node16  -[#595959,plain]-^  node18 : "default_language_id:id"
node10  -[#595959,plain]-^  node10 : "created_by:id"
node3   -[#595959,plain]-^  node0  : "district_id:id"
@enduml
